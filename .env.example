# Optional: only needed if you want to use a Hugging Face hosted LLM endpoint.
# Create a free token from Hugging Face settings and paste it here.
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Choose mode:
# local = uses a local lightweight Hugging Face text generation pipeline
# endpoint = uses Hugging Face Inference Endpoint / Hub model
TELCOGPT_LLM_MODE=local
